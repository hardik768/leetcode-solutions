/*
Problem: 1470. Shuffle the Array
Difficulty: Easy

Time Complexity: O(logn)
Space Complexity: O(1)
*/
class Solution {
public:
    int numberOfMatches(int n) {
        int match=0;
          while(n>1){
            if(n%2==0){
                match+=n/2;
                n/=2;
            }
            else{
                match+=(n-1)/2;
                n=((n-1)/2)+1;
            }

        }
        return match;
    }
};
